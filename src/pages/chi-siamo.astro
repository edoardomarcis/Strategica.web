---
import Base from '../layouts/Base.astro';

const teamMembers = [
  {
    name: "Edoardo Marcis",
    role: "STRATEGIA & GROWTH",
    bio: "Ex startup e open innovation. Strategie di crescita, design thinking e project management strategico. Lettore compulsivo, meditatore. Lo trovi in un surf spot o sul tatami a fare jiu-jitsu.",
    image: "https://picsum.photos/id/1005/600/800"
  },
  {
    name: "Andrea Cavaliere",
    role: "PERFORMANCE & FACILITAZIONE",
    bio: "Oltre 3M€ di budget adv gestiti multi-piattaforma. OKR coach, facilitatore certificato LEGO® Serious Play. Fotografo, videomaker, papà di un border collie.",
    image: "https://picsum.photos/id/1012/600/800"
  },
  {
    name: "Dario Saramin",
    role: "DIGITAL TRANSFORMATION & AI",
    bio: "Ex Senior Manager EY. Guida team attraverso progetti digitali complessi — AI, data monetization, CX. Laurea in conservatorio, MBA Executive ESCP. Sub e sneakerhead.",
    image: "https://picsum.photos/id/1025/600/800"
  }
];
---

<Base
  title="Chi siamo — Strategica"
  description="Un collettivo di professionisti con background diversi, uniti dalla stessa insofferenza per il pressapochismo. Non un'agenzia, non una società di consulenza: quello che mancava."
>

<div class="c-glow" id="glow"></div>

<!-- ── NAV ──────────────────────────────────────────────────────────── -->
<nav>
  <a href="/" class="nav-logo">Strat<em>egica</em></a>
  <ul class="nav-links">
    <li><a href="/#approccio">Approccio</a></li>
    <li><a href="/#servizi">Servizi</a></li>
    <li><a href="/chi-siamo" class="nav-active">Chi siamo</a></li>
    <li><a href="/blog">Blog</a></li>
    <li><a href="/#contatti">Contatti</a></li>
  </ul>
  <a href="/#contatti" class="nav-cta">Inizia qui</a>
</nav>

<!-- ── HERO ─────────────────────────────────────────────────────────── -->
<section class="cs-hero">
  <div class="cs-hero-inner">
    <h1 class="cs-hero-h">
      Non siamo un'agenzia.<br>
      Non siamo una società di consulenza.<br>
      <em>Siamo quello che mancava.</em>
    </h1>
    <p class="cs-hero-sub">
      Un collettivo di professionisti con background diversi, uniti dalla stessa insofferenza per il pressapochismo e dalla stessa idea di cosa significhi fare consulenza davvero.
    </p>
  </div>
  <div class="cs-hero-deco" aria-hidden="true">S</div>
</section>

<!-- ── WAVE dark → cream ──────────────────────────────────────────────── -->
<div class="wave-divider" aria-hidden="true" style="background:var(--dark); margin-bottom:-2px;">
  <svg viewBox="0 0 1440 52" preserveAspectRatio="none" style="height:52px;" fill="none">
    <path d="M0 28 C180 12, 360 44, 540 26 C720 8, 900 42, 1080 24 C1260 8, 1380 36, 1440 22 L1440 52 L0 52 Z" fill="#F2EDE4"/>
    <path d="M0 28 C180 12, 360 44, 540 26 C720 8, 900 42, 1080 24 C1260 8, 1380 36, 1440 22" stroke="rgba(196,98,42,0.1)" stroke-width="1.5" fill="none"/>
  </svg>
</div>

<!-- ── MANIFESTO ─────────────────────────────────────────────────────── -->
<section class="cs-manifesto">
  <div class="cs-manifesto-inner">
    <div class="section-label g-fade">Il Manifesto</div>

    <div class="cs-block g-fade">
      <p class="cs-block-phrase">Siamo stanchi del pressapochismo.</p>
      <p class="cs-block-body">Abbiamo lavorato in startup, in multinazionali, in agenzie. Ovunque la stessa scena: tanta esecuzione, poca strategia. Tante slide, pochi risultati. Strategica nasce da lì — dalla decisione di fare le cose in modo diverso.</p>
    </div>

    <div class="cs-block g-fade">
      <p class="cs-block-phrase">La consulenza non è un deliverable. È un risultato.</p>
      <p class="cs-block-body">Non misuriamo il nostro valore in ore fatturate o documenti consegnati. Lo misuriamo nella crescita concreta dell'azienda con cui lavoriamo. Se il cliente non ottiene risultati, abbiamo fallito noi.</p>
    </div>

    <div class="cs-block g-fade">
      <p class="cs-block-phrase">
        Il nostro obiettivo è
        <em><span class="mark mark-coral">diventare inutili.<svg viewBox="0 0 220 14" fill="none" aria-hidden="true"><path d="M2 10 C40 5, 90 13, 140 8 C175 5, 205 11, 218 8"/></svg></span></em>
      </p>
      <p class="cs-block-body">Non creiamo dipendenza. Costruiamo sistemi, trasferiamo competenze, rendiamo i team autonomi. La consulenza ben fatta ha una data di scadenza.</p>
    </div>

    <div class="cs-block g-fade">
      <p class="cs-block-phrase">Background diversi. Stessa insofferenza.</p>
      <p class="cs-block-body">Veniamo da mondi diversi — startup, big four, performance marketing, innovazione digitale. Ma ci siamo riconosciuti nella stessa frustrazione: il divario tra quello che la consulenza promette e quello che realmente produce. Strategica è la nostra risposta.</p>
    </div>

    <div class="cs-block g-fade">
      <p class="cs-block-phrase">Un collettivo, non un organigramma.</p>
      <p class="cs-block-body">Non siamo una struttura gerarchica. Siamo professionisti senior che scelgono di lavorare insieme perché condividono valori e standard. Ogni progetto ha il team giusto — non quello disponibile.</p>
    </div>
  </div>
</section>

<!-- ── WAVE cream → dark ──────────────────────────────────────────────── -->
<div class="wave-divider" aria-hidden="true" style="background:var(--cream); margin-bottom:-2px;">
  <svg viewBox="0 0 1440 48" preserveAspectRatio="none" style="height:48px;" fill="none">
    <path d="M0 26 C240 8, 480 42, 720 24 C960 6, 1200 40, 1440 18 L1440 48 L0 48 Z" fill="#1C1814"/>
    <path d="M0 26 C240 8, 480 42, 720 24 C960 6, 1200 40, 1440 18" stroke="rgba(255,255,255,0.05)" stroke-width="1.5" fill="none"/>
  </svg>
</div>

<!-- ── TEAM ──────────────────────────────────────────────────────────── -->
<section class="cs-team">
  <div class="cs-team-header g-fade">
    <div class="section-label cs-team-label">Le Persone</div>
    <h2 class="cs-team-h">Facce, non loghi.</h2>
  </div>

  <div class="cs-team-carousel-wrap">
    <div class="cs-team-track" id="teamTrack">
      {teamMembers.map((member) => (
        <article class="tc-card">
          <div class="tc-visual">
            <img
              class="tc-img"
              src={member.image}
              alt={`Foto di ${member.name}`}
              loading="lazy"
              draggable="false"
            />
            <div class="tc-duotone"></div>
          </div>
          <div class="tc-gradient"></div>
          <div class="tc-info">
            <span class="tc-role">{member.role}</span>
            <strong class="tc-name">{member.name}</strong>
            <p class="tc-bio">{member.bio}</p>
          </div>
        </article>
      ))}
    </div>
    <button class="cs-arrow cs-arrow-prev" id="teamPrev" aria-label="Precedente">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M12 4L6 10L12 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <button class="cs-arrow cs-arrow-next" id="teamNext" aria-label="Successivo">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M8 4L14 10L8 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
  </div>

  <div class="cs-team-bg-text" aria-hidden="true">noi</div>
</section>

<!-- ── WAVE dark → cream ──────────────────────────────────────────────── -->
<div class="wave-divider" aria-hidden="true" style="background:var(--dark); margin-bottom:-2px;">
  <svg viewBox="0 0 1440 44" preserveAspectRatio="none" style="height:44px;" fill="none">
    <path d="M0 20 C300 6, 600 36, 900 18 C1100 6, 1280 30, 1440 14 L1440 44 L0 44 Z" fill="#F2EDE4"/>
  </svg>
</div>

<!-- ── CTA ───────────────────────────────────────────────────────────── -->
<section class="cs-cta">
  <div class="cs-cta-left g-l">
    <div class="section-label">Parliamoci</div>
    <h2 class="cs-cta-h">
      Se ti riconosci in questo modo di pensare,
      <em><span class="mark mark-gold">parliamoci.<svg viewBox="0 0 120 14" fill="none"><path d="M2 9 C22 5, 50 13, 78 7 C98 4, 112 11, 118 8"/></svg></span></em>
    </h2>
  </div>
  <div class="cs-cta-right g-r">
    <p>Non servono deck pronti o brief formali. Basta una mail — e capiamo insieme se ha senso parlare.</p>
    <div class="cs-cta-actions">
      <a href="mailto:ciao@strategica.it" class="btn-dark">Scrivici →</a>
      <a href="/#approccio" class="btn-ghost">Scopri come lavoriamo</a>
    </div>
  </div>
</section>

<!-- ── FOOTER ─────────────────────────────────────────────────────────── -->
<footer>
  <div>
    <a href="/" class="footer-logo">Strat<em>egica</em></a>
    <span class="footer-tagline">Costruiamo sistemi operativi aziendali.</span>
  </div>
  <ul class="footer-nav">
    <li><a href="/#approccio">Approccio</a></li>
    <li><a href="/#servizi">Servizi</a></li>
    <li><a href="/chi-siamo">Chi siamo</a></li>
    <li><a href="/#contatti">Contatti</a></li>
  </ul>
  <div class="footer-copy">© 2025 Strategica. Consulenza Strategica. &nbsp;&nbsp; Milano, Italia</div>
</footer>

<script>
  const track = document.getElementById('teamTrack');
  const prevBtn = document.getElementById('teamPrev');
  const nextBtn = document.getElementById('teamNext');

  function updateArrows() {
    if (!track || !prevBtn || !nextBtn) return;
    const scrollLeft = track.scrollLeft;
    const maxScroll = track.scrollWidth - track.clientWidth;
    prevBtn.style.opacity = scrollLeft <= 8 ? '0' : '1';
    prevBtn.style.pointerEvents = scrollLeft <= 8 ? 'none' : 'auto';
    nextBtn.style.opacity = scrollLeft >= maxScroll - 8 ? '0' : '1';
    nextBtn.style.pointerEvents = scrollLeft >= maxScroll - 8 ? 'none' : 'auto';
  }

  function scrollByCard(dir: number) {
    if (!track) return;
    const card = track.querySelector('.tc-card') as HTMLElement;
    if (!card) return;
    track.scrollBy({ left: dir * (card.offsetWidth + 32), behavior: 'smooth' });
  }

  prevBtn?.addEventListener('click', () => scrollByCard(-1));
  nextBtn?.addEventListener('click', () => scrollByCard(1));
  track?.addEventListener('scroll', updateArrows, { passive: true });

  function checkOverflow() {
    if (!track || !prevBtn || !nextBtn) return;
    const hasOverflow = track.scrollWidth > track.clientWidth + 8;
    prevBtn.style.display = hasOverflow ? '' : 'none';
    nextBtn.style.display = hasOverflow ? '' : 'none';
    updateArrows();
  }

  checkOverflow();
  window.addEventListener('resize', checkOverflow);
</script>

</Base>
