---
import Base from '../layouts/Base.astro';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'Strategica',
    url: 'https://strategica.it',
    logo: 'https://strategica.it/logo.png',
    description: 'Consulenza strategica per PMI italiane. Aiutiamo le aziende a costruire il loro sistema operativo.',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Milano',
      addressCountry: 'IT',
    },
    contactPoint: {
      '@type': 'ContactPoint',
      email: 'ciao@strategica.it',
      contactType: 'customer service',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Strategica',
    url: 'https://strategica.it',
  },
];
---

<Base
  title="Strategica · Consulenza Strategica per PMI Italiane"
  description="Consulenza strategica da un collettivo di professionisti. Aiutiamo PMI italiane a costruire il loro sistema operativo: chiarezza, decisioni migliori, crescita misurabile."
  jsonLd={jsonLd}
>

<!-- SVG defs — roughen filter + hand-drawn shapes ───────────────────── -->
<svg style="display:none" aria-hidden="true">
  <defs>
    <!-- Subtle roughen for quote card edges -->
    <filter id="roughen" x="-5%" y="-5%" width="110%" height="110%">
      <feTurbulence type="turbulence" baseFrequency="0.018" numOctaves="3" seed="2" result="noise"/>
      <feDisplacementMap in="SourceGraphic" in2="noise" scale="2.5"
        xChannelSelector="R" yChannelSelector="G"/>
    </filter>
  </defs>
</svg>

<div class="c-glow" id="glow"></div>

<!-- ── SITE HERO ──────────────────────────────────────────────────────── -->
<section class="site-hero">
  <div class="site-hero-inner">
    <p class="sh-wordmark">Strat<em>egica</em></p>
    <p class="sh-tagline">Clarity for builders</p>
    <h1 class="sh-payoff">Progettiamo la crescita aziendale:<br>dalla strategia all'esecuzione.</h1>
    <div class="sh-actions">
      <a href="#contatti" class="btn-white">Inizia qui</a>
      <a href="#approccio" class="btn-ghost-white">Scopri l'approccio</a>
    </div>
  </div>
  <a href="#hero-narrative" class="sh-scroll" aria-label="Scorri verso il basso">
    <span>scroll</span>
    <div class="sh-scroll-line"></div>
  </a>
  <div class="sh-deco" aria-hidden="true">S</div>
</section>

<!-- ── WAVE dark → warm ───────────────────────────────────────────────── -->
<div class="wave-divider" aria-hidden="true" style="background:var(--dark); margin-bottom:-2px;">
  <svg viewBox="0 0 1440 52" preserveAspectRatio="none" style="height:52px;" fill="none">
    <path d="M0 28 C180 12, 360 44, 540 26 C720 8, 900 42, 1080 24 C1260 8, 1380 36, 1440 22 L1440 52 L0 52 Z" fill="#F8F5F0"/>
    <path d="M0 28 C180 12, 360 44, 540 26 C720 8, 900 42, 1080 24 C1260 8, 1380 36, 1440 22" stroke="rgba(196,98,42,0.08)" stroke-width="1.5" fill="none"/>
  </svg>
</div>

<!-- ── NARRATIVE SECTION ──────────────────────────────────────────────── -->
<section class="hero" id="hero-narrative">
  <div class="hero-left">
    <h2 class="hero-headline">
      Il problema reale<br>
      è più in<br>
      <em><span class="mark mark-lime">profondità.<svg viewBox="0 0 120 14" fill="none"><path d="M2 9 C18 5, 38 12, 58 8 C78 4, 98 11, 118 7"/></svg></span></em>
    </h1>
    <p class="hero-body">Le aziende chiedono più lead, più clienti, più tecnologia. Ma raramente è quello il problema. Noi lavoriamo su quello che sta davvero bloccando la crescita.</p>
    <div class="hero-actions">
      <a href="#approccio" class="btn-dark">Scopri l'approccio</a>
      <a href="#servizi" class="btn-ghost">Come lavoriamo</a>
    </div>
  </div>
  <div class="hero-right">
    <div class="hero-decor" aria-hidden="true">S</div>
    <div class="quote-card" id="qcard">
      <!-- Hand-drawn border SVG -->
      <svg class="quote-card-border" viewBox="0 0 400 260" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path d="M8 4 C80 1, 200 3, 320 2 C360 1.5, 394 3, 396 8 C397.5 60, 398 160, 396 252 C394.5 257, 360 259, 320 259 C200 258, 80 259.5, 8 258 C3 257, 1 253, 1 252 C0 200, 0 60, 2 8 C3 4.5, 6 4.2, 8 4Z"
          stroke="rgba(212,200,180,0.65)" stroke-width="1.5" fill="none"/>
      </svg>
      <p>"La consulenza ben fatta non vende al cliente quello che vuole sentirsi dire, ma quello di cui ha davvero bisogno."</p>
      <span class="quote-attr">Il nostro punto di partenza</span>
      <span class="quote-tag">Sistema Operativo Aziendale</span>
    </div>
  </div>
</section>

<!-- ── WAVY DIVIDER hero → metrics ───────────────────────────────────── -->
<div class="wave-divider" aria-hidden="true" style="background:var(--warm); margin-bottom:-2px;">
  <svg viewBox="0 0 1440 36" preserveAspectRatio="none" style="height:36px;" fill="none">
    <path d="M0 18 C200 6, 400 30, 600 16 C800 4, 1040 28, 1240 14 C1340 8, 1400 22, 1440 12 L1440 36 L0 36 Z" fill="#F2EDE4"/>
  </svg>
</div>

<!-- ── METRICS BAND ──────────────────────────────────────────────────── -->
<section class="metrics-band">
  <div class="metric-item">
    <span class="metric-num">30<em>+</em></span>
    <span class="metric-label">Anni di esperienza</span>
    <span class="metric-note">combinata nel team</span>
  </div>
  <div class="metric-item">
    <span class="metric-num">40<em>+</em></span>
    <span class="metric-label">Aziende accompagnate</span>
    <span class="metric-note">PMI e startup italiane</span>
  </div>
  <div class="metric-item">
    <span class="metric-num">3</span>
    <span class="metric-label">Aree di intervento</span>
    <span class="metric-note">strategia · marketing · ops</span>
  </div>
  <div class="metric-item">
    <span class="metric-num"><em>€2M+</em></span>
    <span class="metric-label">Fatturato generato</span>
    <span class="metric-note">nelle aziende clienti</span>
  </div>
</section>

<!-- ── LOGOS MARQUEE ─────────────────────────────────────────────────── -->
<div class="logos-band">
  <div class="logos-band-header">
    <span>Abbiamo lavorato con</span>
  </div>
  <div class="logos-track-wrap">
    <div class="logos-track">
      <!-- Primo set -->
      <span class="logo-item"><span class="logo-dot"></span>Azienda Alfa</span>
      <span class="logo-item"><span class="logo-dot"></span>Studio Beta</span>
      <span class="logo-item"><span class="logo-dot"></span>Gruppo Gamma</span>
      <span class="logo-item"><span class="logo-dot"></span>StartupDelta</span>
      <span class="logo-item"><span class="logo-dot"></span>Holding Epsilon</span>
      <span class="logo-item"><span class="logo-dot"></span>Manifattura Zeta</span>
      <span class="logo-item"><span class="logo-dot"></span>Retail Eta</span>
      <span class="logo-item"><span class="logo-dot"></span>Studio Theta</span>
      <span class="logo-item"><span class="logo-dot"></span>Venture Iota</span>
      <span class="logo-item"><span class="logo-dot"></span>Consulenza Kappa</span>
      <!-- Duplicato per loop infinito -->
      <span class="logo-item"><span class="logo-dot"></span>Azienda Alfa</span>
      <span class="logo-item"><span class="logo-dot"></span>Studio Beta</span>
      <span class="logo-item"><span class="logo-dot"></span>Gruppo Gamma</span>
      <span class="logo-item"><span class="logo-dot"></span>StartupDelta</span>
      <span class="logo-item"><span class="logo-dot"></span>Holding Epsilon</span>
      <span class="logo-item"><span class="logo-dot"></span>Manifattura Zeta</span>
      <span class="logo-item"><span class="logo-dot"></span>Retail Eta</span>
      <span class="logo-item"><span class="logo-dot"></span>Studio Theta</span>
      <span class="logo-item"><span class="logo-dot"></span>Venture Iota</span>
      <span class="logo-item"><span class="logo-dot"></span>Consulenza Kappa</span>
    </div>
  </div>
</div>

<!-- ── WAVY DIVIDER logos → problem ─────────────────────────────────── -->
<div class="wave-divider" aria-hidden="true" style="background:var(--ink); margin-bottom:-2px;">
  <svg viewBox="0 0 1440 48" preserveAspectRatio="none" style="height:48px;" fill="none">
    <path d="M0 24 C120 10, 240 38, 360 24 C480 10, 600 38, 720 22 C840 8, 960 36, 1080 22 C1200 8, 1320 34, 1440 20 L1440 48 L0 48 Z" fill="#1C1814"/>
  </svg>
</div>

<!-- ── PROBLEM ───────────────────────────────────────────────────────── -->
<section class="problem" id="approccio">
  <!-- Header full-width: label + H2 -->
  <div class="problem-header g-fade">
    <div class="section-label">Il vero problema</div>
    <h2>
      Quello che senti è quasi sempre
      <em><span class="mark mark-circle mark-lime">la punta dell'iceberg.<svg viewBox="0 0 200 50" fill="none"><ellipse cx="100" cy="25" rx="96" ry="21" transform="rotate(-1 100 25)"/></svg></span></em>
    </h2>
  </div>

  <!-- Colonna sinistra: solo iceberg grande -->
  <div class="iceberg-col">
    <!-- Iceberg SVG — hand-drawn, animato allo scroll -->
    <div class="iceberg-svg-wrap">
      <svg class="iceberg-svg" id="iceberg" viewBox="0 0 340 520" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <filter id="ice-wobble" x="-8%" y="-4%" width="116%" height="108%">
            <feTurbulence type="turbulence" baseFrequency="0.022" numOctaves="2" seed="14" result="noise"/>
            <feDisplacementMap in="SourceGraphic" in2="noise" scale="3" xChannelSelector="R" yChannelSelector="G"/>
          </filter>
          <!-- Clip per fill sopra l'acqua -->
          <clipPath id="above-water">
            <rect x="0" y="0" width="340" height="162"/>
          </clipPath>
          <!-- Clip per fill sotto l'acqua -->
          <clipPath id="below-water">
            <rect x="0" y="162" width="340" height="360"/>
          </clipPath>
        </defs>

        <!-- Fill sotto acqua — ampio, terracotta più visibile -->
        <path class="iceberg-fill-below"
          d="M 170 162
             C 190 162, 220 158, 248 152
             C 280 144, 308 136, 318 148
             C 328 162, 326 200, 322 240
             C 318 280, 310 320, 304 360
             C 298 400, 296 440, 280 468
             C 264 494, 220 510, 170 512
             C 120 510, 76 494, 60 468
             C 44 440, 42 400, 36 360
             C 30 320, 22 280, 18 240
             C 12 200, 10 162, 22 148
             C 32 136, 60 144, 92 152
             C 120 158, 150 162, 170 162 Z"
          fill="rgba(196,98,42,0.2)" filter="url(#ice-wobble)"/>

        <!-- Fill sopra acqua — leggero bianco caldo -->
        <path class="iceberg-fill-above"
          d="M 170 162
             C 185 162, 200 158, 210 148
             C 222 136, 228 110, 224 88
             C 220 66, 204 40, 190 24
             C 182 14, 176 8, 170 6
             C 164 8, 158 14, 150 24
             C 136 40, 120 66, 116 88
             C 112 110, 118 136, 130 148
             C 140 158, 155 162, 170 162 Z"
          fill="rgba(248,245,240,0.14)" filter="url(#ice-wobble)"/>

        <!-- Outline iceberg completo -->
        <path class="iceberg-outline"
          d="M 170 6
             C 164 8, 154 16, 146 28
             C 134 46, 116 72, 113 96
             C 110 118, 120 140, 133 152
             C 143 162, 156 166, 170 166
             C 184 166, 197 162, 207 152
             C 220 140, 230 118, 227 96
             C 224 72, 206 46, 194 28
             C 186 16, 176 8, 170 6 Z
             M 133 152
             C 110 152, 82 148, 60 152
             C 36 156, 16 164, 16 180
             C 14 210, 12 250, 16 288
             C 20 326, 28 364, 36 396
             C 44 426, 52 452, 60 468
             C 72 488, 110 508, 170 510
             C 230 508, 268 488, 280 468
             C 288 452, 296 426, 304 396
             C 312 364, 320 326, 324 288
             C 328 250, 326 210, 324 180
             C 324 164, 304 156, 280 152
             C 258 148, 230 152, 207 152"
          stroke="rgba(242,237,228,0.82)" stroke-width="1.6"
          stroke-linecap="round" stroke-linejoin="round"
          filter="url(#ice-wobble)"/>

        <!-- Linea del mare — wavy, terracotta -->
        <path class="iceberg-water-line"
          d="M 0 166 C 28 156, 56 174, 86 164 C 116 154, 140 172, 170 163
             C 200 154, 224 172, 254 163 C 284 154, 312 172, 340 162"
          stroke="rgba(196,98,42,0.75)" stroke-width="1.6"
          stroke-linecap="round" filter="url(#ice-wobble)"/>

        <!-- Label "quello che senti" — sopra linea acqua -->
        <text class="iceberg-label" x="170" y="88" text-anchor="middle"
          font-family="Caveat,cursive" font-size="17" fill="rgba(242,237,228,0.6)">quello che senti</text>

        <!-- Label "quello che blocca davvero" — parte sommersa -->
        <text class="iceberg-label" x="170" y="340" text-anchor="middle"
          font-family="Caveat,cursive" font-size="19" fill="rgba(196,98,42,0.85)">quello che</text>
        <text class="iceberg-label" x="170" y="364" text-anchor="middle"
          font-family="Caveat,cursive" font-size="19" fill="rgba(196,98,42,0.85)">blocca davvero</text>

        <!-- Linea tratteggiata verticale — suggerisce la profondità -->
        <line class="iceberg-label" x1="170" y1="178" x2="170" y2="310"
          stroke="rgba(242,237,228,0.15)" stroke-width="1" stroke-dasharray="3 6"/>
      </svg>
    </div>
  </div>
  <div class="problem-right g-r">
    <p>Le aziende arrivano da noi con richieste precise: <strong>più lead, più clienti, più tecnologia, più persone.</strong></p>
    <p>Ma quasi mai il problema è quello. Quello che senti è la reazione allo stimolo. Il problema reale è più in profondità: nel modo in cui l'azienda <strong>prende decisioni, definisce le priorità</strong> e coordina quello che fa.</p>
    <div class="problem-symptoms">
      <div class="symptom"><span class="symptom-num">01.</span>Il marketing non scala nonostante gli investimenti</div>
      <div class="symptom"><span class="symptom-num">02.</span>Il team non è allineato, le priorità cambiano spesso</div>
      <div class="symptom"><span class="symptom-num">03.</span>I margini si comprimono pur lavorando tanto</div>
      <div class="symptom"><span class="symptom-num">04.</span>I risultati non sono proporzionati all'effort</div>
      <div class="symptom"><span class="symptom-num">05.</span>La tecnologia non risolve niente: amplifica</div>
    </div>
  </div>
  <div class="problem-quote g-fade">
    <p>Non partiamo dall'esecuzione. Partiamo da <strong>quello che sta davvero bloccando la crescita.</strong></p>
    <span class="caveat-note">e poi costruiamo da lì insieme.</span>
  </div>
  <div class="problem-bg-text" aria-hidden="true">02</div>
</section>

<!-- ── WAVY DIVIDER problem → approach ───────────────────────────────── -->
<div class="wave-divider" aria-hidden="true" style="background:var(--dark); margin-bottom:-2px;">
  <svg viewBox="0 0 1440 52" preserveAspectRatio="none" style="height:52px;" fill="none">
    <path d="M0 28 C180 12, 360 44, 540 26 C720 8, 900 42, 1080 24 C1260 8, 1380 36, 1440 22 L1440 52 L0 52 Z" fill="#F2EDE4"/>
    <path d="M0 28 C180 12, 360 44, 540 26 C720 8, 900 42, 1080 24 C1260 8, 1380 36, 1440 22" stroke="rgba(196,98,42,0.12)" stroke-width="1.5" fill="none"/>
  </svg>
</div>

<!-- ── APPROACH ──────────────────────────────────────────────────────── -->
<section class="approach" id="approccio-dettaglio">
  <div class="approach-header">
    <div class="g-fade">
      <div class="section-label">Il nostro approccio</div>
      <h2>
        Aiutiamo le aziende a costruire il loro
        <em><span class="mark mark-gold">sistema operativo.<svg viewBox="0 0 160 14" fill="none"><path d="M2 10 C25 6, 55 13, 85 8 C115 3, 140 11, 158 7"/></svg></span></em>
      </h2>
      <p class="approach-lead">La maggior parte delle aziende cresce senza una struttura chiara: progetti frammentati, priorità non allineate, processi decisionali inconsistenti, scarsa visibilità sui dati. Mappiamo dove siete oggi — governance, flussi di lavoro, framework di misurazione, allineamento del team — e disegniamo dove dovete arrivare: il vostro sistema operativo aziendale. Non è una consulting engagement con scadenza. È la struttura con cui prendete decisioni, misurate i risultati, scalate in modo coerente. Una volta in place, continua a funzionare in autonomia.</p>
      <div class="approach-blockquote">
        <p>Il risultato non è più attività: è chiarezza su cosa fare, persone allineate, decisioni più rapide e crescita misurabile.</p>
      </div>
    </div>

    <!-- Venn diagram — 4-circle intersection SVG -->
    <div class="approach-diagram g-r">
      <svg class="venn-svg" viewBox="-130 -70 760 640" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <defs>
          <!-- Subtle hand-drawn wobble -->
          <filter id="wobble" x="-8%" y="-8%" width="116%" height="116%">
            <feTurbulence type="turbulence" baseFrequency="0.018" numOctaves="2" seed="9" result="noise"/>
            <feDisplacementMap in="SourceGraphic" in2="noise" scale="3.5" xChannelSelector="R" yChannelSelector="G"/>
          </filter>
        </defs>

        <!-- 4 circles: top, right, bottom, left — centered at (250,250), offset 85, r=155 -->
        <circle cx="250" cy="165" r="155" stroke="rgba(28,24,20,0.6)"  stroke-width="1.8" filter="url(#wobble)"/>
        <circle cx="335" cy="250" r="155" stroke="rgba(28,24,20,0.6)"  stroke-width="1.8" filter="url(#wobble)"/>
        <circle cx="250" cy="335" r="155" stroke="rgba(28,24,20,0.6)"  stroke-width="1.8" filter="url(#wobble)"/>
        <circle cx="165" cy="250" r="155" stroke="rgba(28,24,20,0.6)"  stroke-width="1.8" filter="url(#wobble)"/>

        <!-- Center intersection — 4-way overlap, convex "pillow" shape -->
        <!-- sweep=1 → arcs bow outward toward each circle's own center, giving convex sides -->
        <path d="M 191.5 308.5
          A 155 155 0 0 1 191.5 191.5
          A 155 155 0 0 1 308.5 191.5
          A 155 155 0 0 1 308.5 308.5
          A 155 155 0 0 1 191.5 308.5 Z"
          fill="rgba(196,98,42,0.78)" filter="url(#wobble)"/>

        <!-- Scribble texture — layered curves to mimic the hand-drawn fill -->
        <g stroke="rgba(220,130,80,0.5)" stroke-width="1.4" stroke-linecap="round" fill="none">
          <path d="M202 238 C212 231,224 229,235 233 C246 237,256 244,262 240"/>
          <path d="M199 249 C211 242,225 240,238 244 C251 248,261 256,268 252"/>
          <path d="M200 260 C214 253,229 251,243 255 C257 259,267 268,272 264"/>
          <path d="M204 271 C218 265,234 263,247 267 C260 271,269 280,274 276"/>
          <path d="M211 281 C224 275,239 274,251 278 C263 282,271 291,275 287"/>
          <path d="M222 291 C233 286,247 286,257 289"/>
          <!-- Cross-hatching -->
          <path d="M206 232 C208 245,209 260,208 275"/>
          <path d="M222 222 C223 238,222 257,220 274"/>
          <path d="M240 218 C240 236,239 258,237 275"/>
          <path d="M258 222 C257 240,256 260,254 277"/>
          <path d="M274 232 C272 248,270 264,268 278"/>
          <path d="M287 248 C284 261,281 274,279 286"/>
        </g>

        <!-- Labels — Caveat, terracotta -->
        <text x="250"  y="-40" text-anchor="middle" font-family="Caveat,cursive" font-size="28" fill="#C4622A">Analisi</text>
        <text x="-110" y="258" text-anchor="start"  font-family="Caveat,cursive" font-size="28" fill="#C4622A">Iterazione</text>
        <text x="610"  y="258" text-anchor="end"    font-family="Caveat,cursive" font-size="28" fill="#C4622A">Co-Design</text>
        <text x="250"  y="542" text-anchor="middle" font-family="Caveat,cursive" font-size="28" fill="#C4622A">Sperimentazione</text>
      </svg>
    </div>
  </div>

  <div class="steps-bento">
    <div class="step-card" tabindex="0" role="button" aria-expanded="false">
      <div class="step-num">01</div>
      <h4>Osserviamo</h4>
      <div class="step-desc"><div>
        <p>Entriamo dentro l'azienda senza preconcetti. Guardiamo come si prendono le decisioni, come fluisce il lavoro, dove si perdono energie e dove invece c'è potenziale inespresso.</p>
      </div></div>
    </div>
    <div class="step-card" tabindex="0" role="button" aria-expanded="false">
      <div class="step-num">02</div>
      <h4>Misuriamo</h4>
      <div class="step-desc"><div>
        <p>Senza dati non si va lontano. Definiamo le metriche giuste e costruiamo la visibilità necessaria per decidere bene.</p>
      </div></div>
    </div>
    <div class="step-card" tabindex="0" role="button" aria-expanded="false">
      <div class="step-num">03</div>
      <h4>Progettiamo</h4>
      <div class="step-desc"><div>
        <p>Identifichiamo le cause reali, non i sintomi, e disegniamo soluzioni concrete adatte alla tua fase di crescita.</p>
      </div></div>
    </div>
    <div class="step-card" tabindex="0" role="button" aria-expanded="false">
      <div class="step-num">04</div>
      <h4>Mettiamo a terra</h4>
      <div class="step-desc"><div>
        <p>Affianchiamo il team nell'esecuzione. Non gestiamo noi: costruiamo insieme un sistema che funziona anche senza di noi.</p>
      </div></div>
    </div>
  </div>
</section>

<!-- ── SERVICES ──────────────────────────────────────────────────────── -->
<section class="services" id="servizi">
  <div class="services-header g-fade">
    <div class="section-label">Come lavoriamo</div>
    <h2>Puoi entrare da dove <em><span class="mark mark-lime">ha più senso per te.<svg viewBox="0 0 150 14" fill="none"><path d="M2 9 C28 5, 60 13, 90 7 C118 2, 138 11, 148 8"/></svg></span></em></h2>
  </div>
  <div class="services-grid">
    <div class="service-card">
      <div class="service-icon-wrap">
        <div class="service-icon">I.</div>
        <!-- Hand-drawn oval — disegnato all'hover -->
        <svg class="service-icon-oval" viewBox="0 0 100 80" fill="none">
          <path d="M50 8 C72 6, 90 18, 92 38 C94 58, 76 72, 50 74 C24 76, 6 62, 6 42 C6 22, 26 10, 50 8Z"
            stroke="rgba(196,98,42,0.3)" stroke-width="1.5" stroke-linecap="round" fill="none"/>
        </svg>
      </div>
      <h3>In-formazione</h3>
      <span class="service-subtitle">il punto di partenza</span>
      <p>Osserviamo l'azienda da fuori, senza preconcetti. Capiamo insieme cosa blocca davvero la crescita e consegni una lettura chiara: i problemi reali, le priorità, il primo passo concreto.</p>
      <div class="service-tags">
        <span class="service-tag">Diagnosi</span>
        <span class="service-tag">Strategia</span>
        <span class="service-tag">Roadmap</span>
      </div>
    </div>
    <div class="service-card">
