---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const allTags = [...new Set(posts.flatMap(p => p.data.tags ?? []))].sort();

const featured = posts[0] ?? null;
const rest = posts.slice(1);

function fmtDate(d: Date) {
  return d.toLocaleDateString('it-IT', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Base
  title="Blog — Strategica"
  description="Riflessioni su strategia, crescita e management per PMI italiane. Articoli pratici per chi vuole capire prima di agire."
  activePage="blog"
>

<div class="c-glow" id="glow"></div>

<!-- ── HEADER dark ────────────────────────────────────────────────────── -->
<header class="blog-hero">
  <div class="blog-hero-inner">
    <div class="section-label blog-hero-label">Riflessioni</div>
    <h1 class="blog-hero-h">
      Idee scritte per<br>
      <em><span class="mark mark-coral">capire prima di agire.<svg viewBox="0 0 300 14" fill="none" aria-hidden="true"><path d="M2 10 C50 5, 120 13, 190 8 C240 4, 280 11, 298 8"/></svg></span></em>
    </h1>
    <p class="blog-hero-sub">Strategia, crescita, management — senza fretta, senza ovvietà.</p>
  </div>
  <div class="blog-hero-deco" aria-hidden="true">B</div>
</header>

<!-- ── WAVE dark → warm ───────────────────────────────────────────────── -->
<div class="wave-divider" aria-hidden="true" style="background:var(--dark); margin-bottom:-2px;">
  <svg viewBox="0 0 1440 52" preserveAspectRatio="none" style="height:52px;" fill="none">
    <path d="M0 28 C180 12, 360 44, 540 26 C720 8, 900 42, 1080 24 C1260 8, 1380 36, 1440 22 L1440 52 L0 52 Z" fill="#F8F5F0"/>
    <path d="M0 28 C180 12, 360 44, 540 26 C720 8, 900 42, 1080 24 C1260 8, 1380 36, 1440 22" stroke="rgba(196,98,42,0.08)" stroke-width="1.5" fill="none"/>
  </svg>
</div>

<!-- ── MAIN ───────────────────────────────────────────────────────────── -->
<main class="blog-main">

  {posts.length === 0 ? (
    <div class="blog-empty">
      <p>I primi articoli sono in arrivo.</p>
    </div>
  ) : (
    <>
      {/* ── Featured post ── */}
      {featured && (
        <a href={`/blog/${featured.slug}`} class="blog-featured" data-tags={(featured.data.tags ?? []).join(',')}>

          {/* Cover template */}
          <div class="bct">
            <div class="bct-top">
              <span class="bct-eyebrow">Ultimo articolo</span>
              <div class="bct-tags">
                {(featured.data.tags ?? []).slice(0, 2).map(tag => (
                  <span class="bct-tag">{tag}</span>
                ))}
              </div>
            </div>
            <h2 class="bct-title">{featured.data.title}</h2>
            <div class="bct-footer">
              <span class="bct-date">{fmtDate(featured.data.pubDate)}</span>
              <span class="bct-logo">Strat<em>egica</em></span>
            </div>
            <span class="bct-deco" aria-hidden="true">
              {(featured.data.tags?.[0] ?? 'S')[0].toUpperCase()}
            </span>
          </div>

          <p class="blog-featured-desc">{featured.data.description}</p>
          <span class="blog-featured-cta">Leggi l'articolo →</span>
        </a>
      )}

      {/* ── Filters (only if there are more posts) ── */}
      {rest.length > 0 && allTags.length > 0 && (
        <div class="blog-filters" id="blog-filters">
          <button class="filter-btn filter-btn--active" data-tag="tutti">Tutti</button>
          {allTags.map(tag => (
            <button class="filter-btn" data-tag={tag}>{tag}</button>
          ))}
        </div>
      )}

      {/* ── Rest of posts ── */}
      {rest.length > 0 && (
        <div class="blog-grid" id="blog-grid">
          {rest.map((post, i) => (
            <a
              href={`/blog/${post.slug}`}
              class="blog-card"
              data-tags={(post.data.tags ?? []).join(',')}
            >
              <span class="blog-card-num">0{i + 2}</span>
              <div class="blog-card-content">
                <div class="blog-card-meta">
                  <span class="blog-date">{fmtDate(post.data.pubDate)}</span>
                  {(post.data.tags ?? []).slice(0, 2).map(tag => (
                    <span class="blog-tag">{tag}</span>
                  ))}
                </div>
                <h3 class="blog-card-title">{post.data.title}</h3>
                <p class="blog-card-desc">{post.data.description}</p>
                <span class="blog-card-cta">Leggi →</span>
              </div>
            </a>
          ))}
        </div>
      )}

      <p class="blog-empty-filter" id="blog-empty-filter" style="display:none">
        Nessun articolo in questa categoria.
      </p>
    </>
  )}
</main>

<!-- ── FOOTER ─────────────────────────────────────────────────────────── -->
<footer>
  <div>
    <a href="/" class="footer-logo">Strat<em>egica</em></a>
    <span class="footer-tagline">Costruiamo sistemi operativi aziendali.</span>
  </div>
  <ul class="footer-nav">
    <li><a href="/#approccio">Approccio</a></li>
    <li><a href="/#servizi">Servizi</a></li>
    <li><a href="/chi-siamo">Chi siamo</a></li>
    <li><a href="/#contatti">Contatti</a></li>
  </ul>
  <div class="footer-copy">© 2025 Strategica. Consulenza Strategica. &nbsp;&nbsp; Milano, Italia</div>
</footer>

<script>
  const filters = document.getElementById('blog-filters');
  const grid    = document.getElementById('blog-grid');
  const empty   = document.getElementById('blog-empty-filter');

  if (filters && grid) {
    filters.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.filter-btn') as HTMLButtonElement | null;
      if (!btn) return;
      const tag = btn.dataset.tag!;
      filters.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('filter-btn--active'));
      btn.classList.add('filter-btn--active');
      let visible = 0;
      grid.querySelectorAll<HTMLElement>('.blog-card').forEach(card => {
        const cardTags = card.dataset.tags ? card.dataset.tags.split(',') : [];
        const show = tag === 'tutti' || cardTags.includes(tag);
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      if (empty) empty.style.display = visible === 0 ? '' : 'none';
    });
  }

</script>

<style>
/* ── Blog hero header ─────────────────────────────────────────────────── */
.blog-hero {
  min-height: 52vh;
  padding: 120px 80px 88px;
  background:
    radial-gradient(ellipse 65% 55% at 100% 10%, rgba(196,98,42,0.12) 0%, transparent 55%),
    radial-gradient(ellipse 40% 50% at 0% 90%,  rgba(168,132,58,0.06) 0%, transparent 55%),
    var(--dark);
  color: var(--cream);
  position: relative; overflow: hidden;
  display: flex; align-items: flex-end;
}
.blog-hero-inner { position: relative; z-index: 1; max-width: 820px; }
.blog-hero-label { color: rgba(242,237,228,0.35); margin-bottom: 28px; }
.blog-hero-label::before { background: var(--terra); }
.blog-hero-h {
  font-size: clamp(40px, 5vw, 76px);
  font-weight: 300; line-height: 1.08; letter-spacing: -0.018em;
  margin-bottom: 28px;
}
.blog-hero-h em { font-style: italic; color: var(--terra); display: block; margin-top: 4px; }
.blog-hero-sub {
  font-family: 'DM Sans', sans-serif;
  font-size: 15px; font-weight: 300; line-height: 1.75;
  color: rgba(242,237,228,0.45);
}
.blog-hero-deco {
  position: absolute; right: -40px; bottom: -100px;
  font-family: 'Cormorant Garamond', serif;
  font-size: 480px; font-weight: 300; font-style: italic; line-height: 1;
  color: transparent;
  -webkit-text-stroke: 1px rgba(196,98,42,0.06);
  pointer-events: none; user-select: none; z-index: 0;
}

/* ── Main container ───────────────────────────────────────────────────── */
.blog-main {
  max-width: 1040px;
  margin: 0 auto;
  padding: 80px 80px 100px;
}

/* ── Shared meta elements ─────────────────────────────────────────────── */
.blog-date {
  font-family: 'DM Sans', sans-serif;
  font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase;
  color: var(--ink-soft);
}
.blog-empty { color: var(--ink-soft); font-style: italic; }
.blog-empty-filter { color: var(--ink-soft); font-style: italic; margin-top: 8px; }

/* ── Featured post ────────────────────────────────────────────────────── */
.blog-featured {
  display: block;
  text-decoration: none;
  padding: 56px 0 60px;
  border-bottom: 1px solid var(--rule-l);
}

/* ── Cover template ───────────────────────────────────────────────────── */
.bct {
  position: relative;
  aspect-ratio: 16 / 7;
  border-radius: 6px;
  overflow: hidden;
  padding: 36px 44px;
  display: flex; flex-direction: column; justify-content: space-between;
  margin-bottom: 36px;
  background:
    radial-gradient(ellipse 70% 80% at 88% 10%, rgba(196,98,42,0.22) 0%, transparent 52%),
    radial-gradient(ellipse 45% 55% at 8% 90%,  rgba(168,132,58,0.10) 0%, transparent 50%),
    var(--dark);
  transition: box-shadow 0.4s ease;
}
.blog-featured:hover .bct {
  box-shadow: 0 16px 56px rgba(60,40,20,0.18), 0 0 0 1px rgba(196,98,42,0.15);
}

.bct-deco {
  position: absolute; right: -16px; bottom: -56px;
  font-family: 'Cormorant Garamond', serif;
  font-size: 300px; font-weight: 300; font-style: italic; line-height: 1;
  color: transparent;
  -webkit-text-stroke: 1px rgba(255,255,255,0.045);
  pointer-events: none; user-select: none;
  transition: -webkit-text-stroke-color 0.45s ease;
}
.blog-featured:hover .bct-deco {
  -webkit-text-stroke-color: rgba(196,98,42,0.08);
}

.bct-top {
  display: flex; align-items: center; gap: 16px;
}
.bct-eyebrow {
  font-family: 'DM Sans', sans-serif;
  font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase;
  color: rgba(242,237,228,0.35);
  display: flex; align-items: center; gap: 10px;
}
.bct-eyebrow::before {
  content: ''; display: block; width: 20px; height: 1px;
  background: rgba(196,98,42,0.6);
}
.bct-tags { display: flex; gap: 7px; }
.bct-tag {
  font-family: 'DM Sans', sans-serif;
  font-size: 9px; letter-spacing: 0.16em; text-transform: uppercase;
  color: var(--terra);
  background: rgba(196,98,42,0.12);
  padding: 4px 10px; border-radius: 4px;
  border: 1px solid rgba(196,98,42,0.2);
}

.bct-title {
  font-size: clamp(26px, 3.2vw, 50px);
  font-weight: 300; line-height: 1.1; letter-spacing: -0.018em;
  color: var(--cream);
  max-width: 72%;
  position: relative; z-index: 1;
  transition: color 0.3s ease;
}
.blog-featured:hover .bct-title { color: #fff; }

.bct-footer {
  display: flex; justify-content: space-between; align-items: flex-end;
  position: relative; z-index: 1;
}
.bct-date {
  font-family: 'DM Sans', sans-serif;
  font-size: 9px; letter-spacing: 0.16em; text-transform: uppercase;
  color: rgba(242,237,228,0.25);
}
.bct-logo {
  font-family: 'Cormorant Garamond', serif;
  font-size: 15px; font-weight: 400; letter-spacing: 0.01em;
  color: rgba(242,237,228,0.3);
  transition: color 0.3s ease;
}
.bct-logo em { font-style: italic; color: rgba(196,98,42,0.55); }
.blog-featured:hover .bct-logo { color: rgba(242,237,228,0.5); }
.blog-featured:hover .bct-logo em { color: rgba(196,98,42,0.85); }

.blog-featured-desc {
  font-size: 18px; font-weight: 300; line-height: 1.74;
  color: var(--ink-soft); max-width: 640px;
  margin-bottom: 28px;
}
.blog-featured-cta {
  font-family: 'DM Sans', sans-serif;
  font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase;
  color: var(--terra);
  display: inline-block;
  transition: letter-spacing 0.25s;
}
.blog-featured:hover .blog-featured-cta { letter-spacing: 0.22em; }

/* ── Filters ──────────────────────────────────────────────────────────── */
.blog-filters {
  display: flex; flex-wrap: wrap; gap: 8px;
  padding: 40px 0 0;
  border-top: 1px solid var(--rule-l);
  margin-top: 0;
  margin-bottom: 8px;
}
.filter-btn {
  font-family: 'DM Sans', sans-serif;
  font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase;
  padding: 7px 16px;
  border-radius: 4px;
  border: 1px solid rgba(196,98,42,0.2);
  background: transparent;
  color: var(--ink-soft);
  cursor: pointer;
  transition: color .2s, border-color .2s, background .2s;
}
.filter-btn:hover { color: var(--terra); border-color: rgba(196,98,42,0.5); }
.filter-btn--active {
  color: var(--terra);
  border-color: var(--terra);
  background: rgba(196,98,42,0.06);
}

/* ── Blog grid (secondary posts) ─────────────────────────────────────── */
.blog-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  column-gap: 64px;
}

.blog-card {
  display: grid;
  grid-template-columns: 52px 1fr;
  gap: 0 24px;
  padding: 40px 0;
  border-bottom: 1px solid var(--rule-l);
  text-decoration: none;
  transition: opacity 0.2s;
  align-items: start;
}
.blog-card:hover { opacity: 1; }

.blog-card-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 13px; font-weight: 300; letter-spacing: 0.06em;
  color: rgba(92,80,72,0.35);
  padding-top: 3px;
  transition: color 0.25s;
}
.blog-card:hover .blog-card-num { color: var(--terra); }

.blog-card-content { display: flex; flex-direction: column; }
.blog-card-meta {
  display: flex; align-items: center; gap: 10px;
  margin-bottom: 12px;
}
.blog-card-title {
  font-size: clamp(20px, 2vw, 26px);
  font-weight: 300; line-height: 1.2; letter-spacing: -0.01em;
  color: var(--ink); margin-bottom: 10px;
  transition: color 0.25s;
}
.blog-card:hover .blog-card-title { color: var(--terra); }
.blog-card-desc {
  font-size: 15px; font-weight: 300;
  line-height: 1.72; color: var(--ink-soft);
  margin-bottom: 16px;
}
.blog-card-cta {
  font-family: 'DM Sans', sans-serif;
  font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase;
  color: var(--terra);
  transition: letter-spacing 0.25s;
}
.blog-card:hover .blog-card-cta { letter-spacing: 0.22em; }

/* ── Responsive ───────────────────────────────────────────────────────── */
@media (max-width: 900px) {
  .blog-hero { padding: 96px 24px 64px; min-height: auto; }
  .blog-hero-deco { display: none; }
  .blog-hero-h { font-size: clamp(32px, 8vw, 52px); }
  .blog-main { padding: 56px 24px 72px; }
  .bct { aspect-ratio: 4 / 3; padding: 24px 28px; margin-bottom: 24px; }
  .bct-title { max-width: 90%; font-size: clamp(22px, 6vw, 34px); }
  .bct-deco { font-size: 200px; right: -10px; bottom: -40px; }
  .blog-featured-desc { font-size: 16px; }
  .blog-grid { grid-template-columns: 1fr; }
  .blog-card { grid-template-columns: 40px 1fr; gap: 0 16px; }
}
</style>

</Base>
