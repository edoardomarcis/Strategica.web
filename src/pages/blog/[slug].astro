---
import Base from '../../layouts/Base.astro';
import BlogCover from '../../components/BlogCover.astro';
import { article } from '../../utils/jsonld';
import { authors } from '../../utils/authors';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const author = authors[post.data.author];
const jsonLd = article(post);
---

<Base
  title={`${post.data.title} · Strategica`}
  description={post.data.description}
  ogType="article"
  ogImage={post.data.coverImage}
  article={{
    publishedTime: post.data.pubDate.toISOString(),
    author: post.data.author,
    tags: post.data.tags,
  }}
  jsonLd={jsonLd}
>

<div class="c-glow" id="glow"></div>

<article class="post-main">
  <header class="post-header">
    <a href="/blog" class="post-back">← Blog</a>
    <div class="post-meta">
      <span class="post-date">
        {post.data.pubDate.toLocaleDateString('it-IT', { year: 'numeric', month: 'long', day: 'numeric' })}
      </span>
      {post.data.tags && post.data.tags.map(tag => (
        <span class="blog-tag">{tag}</span>
      ))}
    </div>
    <h1 class="post-title">{post.data.title}</h1>
    <p class="post-desc">{post.data.description}</p>
    <div class="post-author">
      <span class="post-author-name">{post.data.author}</span>
    </div>
  </header>

  <div class="post-cover">
    {post.data.coverImage
      ? <img src={post.data.coverImage} alt={post.data.title} />
      : <BlogCover title={post.data.title} tags={post.data.tags} slug={post.slug} />}
  </div>

  <div class="post-body">
    <Content />
  </div>

  {author && (
    <aside class="post-author-box">
      <img class="pab-photo" src={author.photo} alt={author.name} width="72" height="72" />
      <div class="pab-content">
        <span class="pab-role">{author.role}</span>
        <strong class="pab-name">{author.name}</strong>
        <p class="pab-bio">{author.bio}</p>
        <a href={author.linkedin} target="_blank" rel="noopener noreferrer" class="pab-link">LinkedIn →</a>
      </div>
    </aside>
  )}

  <footer class="post-footer">
    <a href="/blog" class="btn-ghost">Tutti gli articoli</a>
    <a href="/#contatti" class="btn-dark">Parliamone</a>
  </footer>
</article>

<!-- FOOTER -->
<footer>
  <div>
    <a href="/" class="footer-logo">Strat<em>egica</em></a>
    <span class="footer-tagline">Costruiamo sistemi operativi aziendali.</span>
  </div>
  <ul class="footer-nav">
    <li><a href="/#approccio">Approccio</a></li>
    <li><a href="/#servizi">Servizi</a></li>
    <li><a href="/chi-siamo">Chi siamo</a></li>
    <li><a href="/blog">Blog</a></li>
    <li><a href="/#contatti">Contatti</a></li>
  <li><a href="/privacy">Privacy</a></li>
  </ul>
  <span class="footer-copy">© 2025 Strategica</span>
</footer>

<style>
.post-main {
  max-width: 760px;
  margin: 0 auto;
  padding: 120px 40px 96px;
}
.post-back {
  font-family: 'DM Sans', sans-serif;
  font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase;
  color: var(--ink-soft); text-decoration: none;
  display: inline-block; margin-bottom: 48px;
  transition: color .2s;
}
.post-back:hover { color: var(--terra); }
.post-meta {
  display: flex; align-items: center; gap: 12px;
  margin-bottom: 24px;
}
.post-date {
  font-family: 'DM Sans', sans-serif;
  font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase;
  color: var(--ink-soft);
}
.post-title {
  font-size: clamp(36px, 5vw, 68px);
  font-weight: 300; line-height: 1.06;
  letter-spacing: -0.02em; color: var(--ink);
  margin-bottom: 20px;
}
.post-desc {
  font-size: 20px; font-weight: 300;
  color: var(--ink-soft); line-height: 1.68;
  margin-bottom: 28px;
}
.post-author {
  display: flex; align-items: center; gap: 12px;
  padding-top: 28px; border-top: 1px solid var(--rule-l);
  margin-bottom: 64px;
}
.post-author-name {
  font-family: 'Caveat', cursive;
  font-size: 18px; color: var(--terra);
}

/* Cover image */
.post-cover {
  width: 100%;
  aspect-ratio: 16 / 9;
  border-radius: 6px;
  overflow: hidden;
  margin-bottom: 56px;
}
.post-cover img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
}

/* Post body — stile editoriale */
.post-body {
  font-size: 19px; line-height: 1.8;
  color: var(--ink);
  border-top: 1px solid var(--rule-l);
  padding-top: 48px;
}
.post-cover + .post-body {
  border-top: none;
  padding-top: 0;
}
.post-body h2 {
  font-size: clamp(28px, 3vw, 40px);
  font-weight: 300; letter-spacing: -0.012em;
  margin: 56px 0 20px; line-height: 1.12;
}
.post-body h3 {
  font-size: clamp(22px, 2.2vw, 28px);
  font-weight: 400; margin: 40px 0 16px;
}
.post-body p { margin-bottom: 24px; color: var(--ink-soft); font-weight: 300; }
/* Drop cap sul primo paragrafo */
.post-body > :global(p:first-of-type)::first-letter {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: 74px; line-height: 0.8;
  float: left; padding: 9px 12px 0 0;
  color: var(--terra); font-weight: 300;
}
.post-body strong { color: var(--ink); font-weight: 400; }
.post-body em { font-style: italic; color: var(--terra); }
.post-body blockquote {
  border-left: 3px solid var(--terra);
  padding: 16px 20px; margin: 32px 0;
  background: rgba(196,98,42,0.04);
  border-radius: 0 6px 6px 0;
  font-style: italic;
}
.post-body blockquote p { color: var(--ink); margin: 0; }
.post-body ul, .post-body ol {
  padding-left: 24px; margin-bottom: 24px;
}
.post-body li { margin-bottom: 10px; color: var(--ink-soft); font-weight: 300; }
.post-body hr {
  border: none; border-top: 1px solid var(--rule-l);
  margin: 48px 0;
}
.post-body a { color: var(--terra); text-decoration: underline; text-underline-offset: 3px; }

/* Box autore — E-E-A-T */
.post-author-box {
  display: flex; gap: 24px; align-items: flex-start;
  margin-top: 64px; padding-top: 40px;
  border-top: 1px solid var(--rule-l);
}
.pab-photo {
  flex-shrink: 0;
  width: 72px; height: 72px; border-radius: 20px;
  object-fit: cover;
}
.pab-role {
  font-family: 'DM Sans', sans-serif;
  font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase;
  color: var(--terra); display: block; margin-bottom: 4px;
}
.pab-name {
  font-size: 22px; font-weight: 400; color: var(--ink);
  display: block; margin-bottom: 8px;
}
.pab-bio {
  font-size: 17px; font-weight: 300; line-height: 1.7;
  color: var(--ink-soft); margin-bottom: 12px;
}
.pab-link {
  font-family: 'DM Sans', sans-serif;
  font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase;
  color: var(--ink-soft); text-decoration: none;
  border-bottom: 1px solid var(--rule);
  padding-bottom: 2px; transition: color .2s, border-color .2s;
}
.pab-link:hover { color: var(--terra); border-color: var(--terra); }

.post-footer {
  display: flex; gap: 20px; align-items: center;
  margin-top: 72px; padding-top: 40px;
  border-top: 1px solid var(--rule-l);
}

@media (max-width: 768px) {
  .post-main { padding: 96px 24px 64px; }
  .post-footer { flex-direction: column; align-items: flex-start; }
}
</style>

</Base>
