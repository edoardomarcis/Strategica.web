---
import { SEO } from 'astro-seo';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  article?: {
    publishedTime?: string;
    author?: string;
    tags?: string[];
  };
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = 'Strategica — Consulenza Strategica per PMI Italiane',
  description = 'Consulenza strategica per PMI italiane. Aiutiamo le aziende a costruire il loro sistema operativo: chiarezza, decisioni migliori, crescita misurabile.',
  canonical,
  ogImage,
  ogType = 'website',
  noindex = false,
  article,
  jsonLd,
} = Astro.props;

const SITE = 'https://strategica.it';
const DEFAULT_OG_IMAGE = `${SITE}/og-default.jpg`;
const canonicalURL = canonical ?? new URL(Astro.url.pathname, SITE).href;
const ogImageURL = ogImage ? new URL(ogImage, SITE).href : DEFAULT_OG_IMAGE;
---

<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<SEO
  title={title}
  description={description}
  canonical={canonicalURL}
  noindex={noindex}
  openGraph={{
    basic: {
      title: title,
      type: ogType,
      image: ogImageURL,
      url: canonicalURL,
    },
    optional: {
      description: description,
      locale: 'it_IT',
      siteName: 'Strategica',
    },
    ...(ogType === 'article' && article ? {
      article: {
        publishedTime: article.publishedTime,
        authors: article.author ? [article.author] : undefined,
        tags: article.tags,
      }
    } : {}),
  }}
  twitter={{
    card: ogImageURL ? 'summary_large_image' : 'summary',
    site: '@strategica_it',
    creator: '@edoardomarcis',
    ...(ogImageURL ? { image: ogImageURL, imageAlt: title } : {}),
  }}
  extend={{
    meta: [
      { name: 'author', content: 'Edoardo Marcis' },
    ],
  }}
/>

{jsonLd && (
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
)}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=DM+Sans:opsz,wght@9..40,300;9..40,400&family=Caveat:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/styles/global.css">
</head>
<body>

<slot />

<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
<script is:inline src="/scripts/main.js"></script>

</body>
</html>
