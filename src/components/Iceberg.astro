---
---
<svg class="iceberg-svg" id="iceberg" viewBox="34 46 426 492" fill="none" xmlns="http://www.w3.org/2000/svg"
  role="img" aria-label="Tavola tecnica: sezione di un iceberg. Sopra la linea di galleggiamento, piccola, la parte visibile con le richieste. Sotto, molto più grande, la massa con le cause reali: decisioni, priorità, coordinamento, misura.">
  <defs>
    <filter id="ice-wobble" x="-8%" y="-4%" width="116%" height="108%">
      <feTurbulence type="turbulence" baseFrequency="0.022" numOctaves="2" seed="14" result="noise"/>
      <feDisplacementMap in="SourceGraphic" in2="noise" scale="2.2" xChannelSelector="R" yChannelSelector="G"/>
    </filter>
    <linearGradient id="ice-abisso" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="rgba(51,36,23,0.25)"/>
      <stop offset="0.42" stop-color="rgba(43,29,18,0.45)"/>
      <stop offset="1" stop-color="rgba(34,21,9,0.7)"/>
    </linearGradient>
    <pattern id="ice-hatch" width="7" height="7" patternTransform="rotate(45)" patternUnits="userSpaceOnUse">
      <line x1="0" y1="0" x2="0" y2="7" stroke="#F2EDE4" stroke-width="0.6" opacity="0.22"/>
    </pattern>
  </defs>

  <!-- il mare -->
  <rect class="ib-sea" x="0" y="168" width="460" height="392" fill="url(#ice-abisso)"/>

  <!-- scala di profondità -->
  <g class="ib-fade ib-f1" font-family="'DM Sans',sans-serif" font-size="9.5" fill="rgba(242,237,228,0.45)" letter-spacing="0.08em">
    <path d="M448 168 v382 M444 238 h8 M444 308 h8 M444 378 h8 M444 448 h8 M444 518 h8" stroke="rgba(242,237,228,0.3)" stroke-width="0.8"/>
    <text x="438" y="242" text-anchor="end">Q.−05</text>
    <text x="438" y="312" text-anchor="end">Q.−10</text>
    <text x="438" y="382" text-anchor="end">Q.−15</text>
    <text x="438" y="452" text-anchor="end">Q.−20</text>
  </g>

  <!-- punta emersa -->
  <path class="ib-draw ib-tip" d="M196 96 L226 58 L262 88 L280 124 L270 142 L206 142 L186 120 Z"
    stroke="rgba(242,237,228,0.85)" stroke-width="1.6" stroke-linejoin="round"
    fill="rgba(242,237,228,0.1)" filter="url(#ice-wobble)"/>

  <!-- richiamo: parte visibile -->
  <g class="ib-fade ib-f1">
    <path d="M280 92 h84" stroke="rgba(242,237,228,0.35)" stroke-width="0.8"/>
    <text x="368" y="88" font-family="'DM Sans',sans-serif" font-size="10" letter-spacing="0.12em" fill="rgba(242,237,228,0.6)">PARTE VISIBILE:</text>
    <text x="368" y="102" font-family="'DM Sans',sans-serif" font-size="10" letter-spacing="0.12em" fill="rgba(242,237,228,0.6)">LE RICHIESTE</text>
    <text x="368" y="122" font-family="Caveat,cursive" font-size="14" fill="rgba(242,237,228,0.45)">lead · clienti ·</text>
    <text x="368" y="138" font-family="Caveat,cursive" font-size="14" fill="rgba(242,237,228,0.45)">tecnologia · persone</text>
  </g>

  <!-- linea di galleggiamento -->
  <path class="ib-draw ib-water" d="M16 168 H 444" stroke="rgba(196,98,42,0.9)" stroke-width="1.6"
    stroke-dasharray="8 5" stroke-linecap="round" filter="url(#ice-wobble)"/>
  <text class="ib-fade ib-f2" x="16" y="158" font-family="'DM Sans',sans-serif" font-size="9.5" letter-spacing="0.18em" fill="rgba(212,120,74,0.95)">LINEA DI GALLEGGIAMENTO · Q. 0</text>

  <!-- massa sommersa -->
  <path class="ib-draw ib-mass" d="M186 144 L206 142 L270 142 L280 144 L330 208 L366 306 L342 424 L272 516 L206 528 L142 438 L112 322 L138 226 Z"
    stroke="rgba(242,237,228,0.6)" stroke-width="1.3" stroke-linejoin="round"
    fill="url(#ice-hatch)" filter="url(#ice-wobble)"/>

  <!-- le cause, livello per livello -->
  <g font-family="'Cormorant Garamond',serif" font-size="15" font-style="italic" fill="rgba(242,237,228,0.92)">
    <g class="ib-fade ib-f2"><circle cx="236" cy="238" r="3.4" fill="#FF6B4A"/><text x="250" y="243">come si prendono le decisioni</text></g>
    <g class="ib-fade ib-f3"><circle cx="224" cy="308" r="3.4" fill="#FF6B4A"/><text x="238" y="313">come si definiscono le priorità</text></g>
    <g class="ib-fade ib-f4"><circle cx="232" cy="378" r="3.4" fill="#FF6B4A"/><text x="246" y="383">come si coordina il lavoro</text></g>
    <g class="ib-fade ib-f5"><circle cx="242" cy="448" r="3.4" fill="#FF6B4A"/><text x="256" y="453">come si misurano i risultati</text></g>
  </g>

  <!-- quote di proporzione -->
  <g class="ib-fade ib-f5" font-family="'DM Sans',sans-serif" font-size="9.5" letter-spacing="0.14em">
    <path d="M64 58 v110 M58 58 h12" stroke="rgba(242,237,228,0.35)" stroke-width="0.8"/>
    <text x="46" y="120" fill="rgba(242,237,228,0.5)" transform="rotate(-90 46 120)">1/8 VISIBILE</text>
    <path d="M64 168 v360 M58 528 h12 M60 168 h8" stroke="rgba(242,237,228,0.35)" stroke-width="0.8"/>
    <text x="46" y="400" fill="rgba(242,237,228,0.8)" transform="rotate(-90 46 400)">7/8 SOMMERSO</text>
  </g>
</svg>
