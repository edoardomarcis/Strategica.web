---
---
<svg class="iceberg-svg" id="iceberg" viewBox="0 0 340 520" fill="none" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <filter id="ice-wobble" x="-8%" y="-4%" width="116%" height="108%">
      <feTurbulence type="turbulence" baseFrequency="0.022" numOctaves="2" seed="14" result="noise"/>
      <feDisplacementMap in="SourceGraphic" in2="noise" scale="2.5" xChannelSelector="R" yChannelSelector="G"/>
    </filter>
  </defs>

  <!-- Massa sommersa — sfaccettata, angolare -->
  <path class="iceberg-fill-below"
    d="M 100 162 L 238 162 L 292 188 L 314 254 L 296 332 L 256 414 L 196 478 L 156 496 L 110 452 L 66 378 L 40 282 L 52 206 Z"
    fill="rgba(196,98,42,0.24)" filter="url(#ice-wobble)"/>

  <!-- Hatching interno — coerente con il tratteggio del venn -->
  <g class="iceberg-hatch" stroke="rgba(212,120,74,0.38)" stroke-width="1.3" stroke-linecap="round" filter="url(#ice-wobble)">
    <path d="M 76 220 C 84 268, 94 320, 108 368"/>
    <path d="M 104 200 C 112 258, 124 322, 140 392"/>
    <path d="M 134 186 C 140 256, 148 340, 158 428"/>
    <path d="M 166 178 C 170 254, 174 350, 178 444"/>
    <path d="M 198 180 C 200 250, 200 340, 196 424"/>
    <path d="M 228 186 C 230 244, 226 316, 216 388"/>
    <path d="M 258 200 C 260 246, 254 300, 242 356"/>
    <path d="M 284 224 C 284 258, 278 296, 268 336"/>
  </g>

  <!-- Punta emersa — piena, crema: è la parte che si vede -->
  <path class="iceberg-fill-above"
    d="M 100 162 L 124 126 L 140 138 L 166 60 L 188 106 L 204 90 L 226 138 L 238 162 Z"
    fill="rgba(242,237,228,0.88)" filter="url(#ice-wobble)"/>

  <!-- Contorno unico: punta + massa, disegnato allo scroll -->
  <path class="iceberg-outline"
    d="M 100 162 L 124 126 L 140 138 L 166 60 L 188 106 L 204 90 L 226 138 L 238 162
       L 292 188 L 314 254 L 296 332 L 256 414 L 196 478 L 156 496 L 110 452 L 66 378 L 40 282 L 52 206 L 100 162"
    stroke="rgba(242,237,228,0.85)" stroke-width="1.8"
    stroke-linecap="round" stroke-linejoin="round"
    filter="url(#ice-wobble)"/>

  <!-- Spigoli interni — danno volume -->
  <g class="iceberg-facet" stroke="rgba(242,237,228,0.16)" stroke-width="1.2" stroke-linecap="round" filter="url(#ice-wobble)">
    <path d="M 166 60 L 174 162"/>
    <path d="M 226 138 L 208 162"/>
    <path d="M 174 166 L 148 300 L 168 436"/>
    <path d="M 238 164 L 250 270 L 220 392"/>
    <path d="M 100 164 L 116 262 L 148 372"/>
  </g>

  <path class="iceberg-water-line"
    d="M 0 166 C 28 156, 56 174, 86 164 C 116 154, 140 172, 170 163
       C 200 154, 224 172, 254 163 C 284 154, 312 172, 340 162"
    stroke="rgba(196,98,42,0.85)" stroke-width="1.8"
    stroke-linecap="round" filter="url(#ice-wobble)"/>

  <text class="iceberg-label" x="170" y="152" text-anchor="middle"
    font-family="Caveat,cursive" font-size="16" fill="rgba(28,24,20,0.72)">quello che senti</text>

  <text class="iceberg-label" x="170" y="336" text-anchor="middle"
    font-family="Caveat,cursive" font-size="21" fill="rgba(228,150,100,0.95)">quello che</text>
  <text class="iceberg-label" x="170" y="362" text-anchor="middle"
    font-family="Caveat,cursive" font-size="21" fill="rgba(228,150,100,0.95)">blocca davvero</text>

  <line class="iceberg-label" x1="170" y1="190" x2="170" y2="304"
    stroke="rgba(242,237,228,0.18)" stroke-width="1" stroke-dasharray="3 6"/>
</svg>
