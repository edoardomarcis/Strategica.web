---
interface Props {
  color: 'coral' | 'lime' | 'gold';
  viewBox: string;
  path?: string;
  circle?: boolean;
  cx?: number;
  cy?: number;
  rx?: number;
  ry?: number;
}

const { color, viewBox, path, circle = false, cx = 100, cy = 25, rx = 96, ry = 21 } = Astro.props;
---

<span class={`mark mark-${color}${circle ? ' mark-circle' : ''}`}><slot /><svg viewBox={viewBox} fill="none" aria-hidden="true">{circle ? <ellipse cx={cx} cy={cy} rx={rx} ry={ry} transform={`rotate(-1 ${cx} ${cy})`} /> : <path d={path} />}</svg></span>
