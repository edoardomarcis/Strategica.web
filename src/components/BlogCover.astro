---
interface Props {
  title: string;
  pubDate: Date;
  index: number;
}

const { title, pubDate, index } = Astro.props;

const initial = title.trim().charAt(0).toUpperCase();
const num = String(index).padStart(2, '0');
const dateStr = pubDate.toLocaleDateString('it-IT', { year: 'numeric', month: 'long', day: 'numeric' });
---

<div class="blog-cover" role="img" aria-label={title}>
  <span class="bc-num">{num}</span>

  <h2 class="bc-title">{title}</h2>

  <div class="bc-footer">
    <span class="bc-date">{dateStr}</span>
    <span class="bc-logo">Strat<em>egica</em></span>
  </div>

  <span class="bc-deco" aria-hidden="true">{initial}</span>
</div>

<style>
.blog-cover {
  position: relative;
  width: 100%;
  height: 100%;
  padding: 40px 48px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  background:
    radial-gradient(ellipse 70% 80% at 88% 10%, rgba(196,98,42,0.22) 0%, transparent 52%),
    radial-gradient(ellipse 45% 55% at 8% 90%,  rgba(168,132,58,0.10) 0%, transparent 50%),
    var(--dark);
  overflow: hidden;
}

.bc-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 16px;
  font-weight: 400;
  letter-spacing: 0.08em;
  color: rgba(196,98,42,0.7);
  align-self: flex-end;
  position: relative;
  z-index: 1;
}

.bc-title {
  font-size: clamp(24px, 4.2vw, 34px);
  font-weight: 300;
  line-height: 1.16;
  letter-spacing: -0.018em;
  color: var(--cream);
  max-width: 84%;
  position: relative;
  z-index: 1;
}

.bc-footer {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  position: relative;
  z-index: 1;
}

.bc-date {
  font-family: 'DM Sans', sans-serif;
  font-size: 10px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: rgba(242,237,228,0.3);
}

.bc-logo {
  font-family: 'Cormorant Garamond', serif;
  font-size: 16px;
  font-weight: 400;
  letter-spacing: 0.01em;
  color: rgba(242,237,228,0.4);
}
.bc-logo em { font-style: italic; color: rgba(196,98,42,0.65); }

.bc-deco {
  position: absolute;
  right: -24px;
  bottom: -72px;
  font-family: 'Cormorant Garamond', serif;
  font-size: 320px;
  font-weight: 300;
  font-style: italic;
  line-height: 1;
  color: transparent;
  -webkit-text-stroke: 1px rgba(255,255,255,0.045);
  pointer-events: none;
  user-select: none;
  z-index: 0;
}

@media (max-width: 640px) {
  .blog-cover { padding: 24px 24px; }
  .bc-title { max-width: 92%; font-size: clamp(20px, 6vw, 26px); }
  .bc-deco { font-size: 170px; right: -12px; bottom: -34px; }
}
</style>
