---
interface Props {
  title: string;
  tags?: string[];
  slug: string;
}

const { title, tags = [], slug } = Astro.props;

const initial = title.trim().charAt(0).toUpperCase();
const word = tags[0] ?? 'Riflessioni';

// Variazione deterministica per post: accento annotazione + seed della curva
const hash = [...slug].reduce((a, c) => a + c.charCodeAt(0), 0);
const accents = ['#FF6B4A', '#A8E63D', '#E8C547'];
const accent = accents[hash % 3];
const underlines = [
  'M4 12 C60 4, 150 16, 240 8 C300 3, 340 12, 376 7',
  'M4 10 C80 16, 170 2, 260 12 C320 17, 356 6, 376 10',
  'M4 8 C70 14, 160 4, 250 13 C310 18, 350 5, 376 9',
];
const underline = underlines[hash % underlines.length];
---

<svg class="blog-cover-svg" viewBox="0 0 1200 675" xmlns="http://www.w3.org/2000/svg" role="img" aria-label={title}>
  <defs>
    <radialGradient id={`bc-terra-${slug}`} cx="85%" cy="12%" r="75%">
      <stop offset="0%" stop-color="rgba(196,98,42,0.28)"/>
      <stop offset="55%" stop-color="rgba(196,98,42,0)"/>
    </radialGradient>
    <radialGradient id={`bc-gold-${slug}`} cx="8%" cy="95%" r="65%">
      <stop offset="0%" stop-color="rgba(168,132,58,0.14)"/>
      <stop offset="60%" stop-color="rgba(168,132,58,0)"/>
    </radialGradient>
  </defs>

  <rect width="1200" height="675" fill="#1C1814"/>
  <rect width="1200" height="675" fill={`url(#bc-terra-${slug})`}/>
  <rect width="1200" height="675" fill={`url(#bc-gold-${slug})`}/>

  <!-- Lettera decorativa — come i bg-text delle sezioni dark -->
  <text x="1160" y="620" text-anchor="end"
    font-family="'Cormorant Garamond',Georgia,serif" font-style="italic" font-weight="300"
    font-size="640" letter-spacing="-0.03em"
    fill="rgba(242,237,228,0.045)" stroke="rgba(242,237,228,0.07)" stroke-width="1.5">{initial}</text>

  <!-- Linea d'acqua a mano — richiama l'iceberg -->
  <path d="M0 520 C90 505, 180 532, 280 518 C390 502, 480 534, 590 519 C700 504, 790 531, 900 517 C1010 503, 1110 528, 1200 515"
    stroke="rgba(196,98,42,0.32)" stroke-width="2" stroke-linecap="round" fill="none"/>

  <!-- Wordmark -->
  <text x="72" y="96" font-family="'Cormorant Garamond',Georgia,serif" font-weight="300" font-size="44" letter-spacing="-0.02em">
    <tspan fill="#F2EDE4">Strat</tspan><tspan fill="#C4622A" font-style="italic">egica</tspan>
  </text>

  <!-- Tag in Caveat con annotazione -->
  <text x="76" y="565" font-family="Caveat,cursive" font-size="64" fill="#F2EDE4">{word}</text>
  <g transform="translate(72, 580)">
    <path d={underline} stroke={accent} stroke-width="4" stroke-linecap="round" fill="none"/>
  </g>
</svg>

<style>
.blog-cover-svg { display: block; width: 100%; height: 100%; }
</style>
