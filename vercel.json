{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "strategica-web.vercel.app" }],
      "destination": "https://www.wearestrategica.com/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
